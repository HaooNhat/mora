{
  "extends": "@workspace/typescript-config/base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@workspace/domain/*": ["../domain/src/*"],
      "@workspace/application/*": ["../application/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}

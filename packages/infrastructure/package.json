{
  "name": "@workspace/infrastructure",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "lint": "eslint . --max-warnings 0",
    "gen:types": "npx supabase gen types typescript --project-id $PROJECT_ID > src/database/supabase.types.ts",
    "db:start": "pnpx supabase start",
    "db:gen-schema": "supabase db diff -f my_schema",
    "db:gen-seed": "supabase db dump --local --data-only > supabase/seed.sql"
  },
  "dependencies": {
    "@workspace/domain": "workspace:*",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.17",
    "@workspace/typescript-config": "workspace:*"
  },
  "exports": {
    "./*": "./dist/*.js"
  }
}

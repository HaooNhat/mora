{
  "extends": "@workspace/typescript-config/base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "baseUrl": ".",

    "paths": {
      "@/*": ["./src/*"],
      "@workspace/core/*": ["../core/src/*"],
      "@workspace/api-client/*": ["../api-client/src/*"],
      "@workspace/ui/*": ["../ui/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}

{
  "extends": "@workspace/typescript-config/react-library.json",
  "include": ["src"],
  "exclude": ["node_modules", "dist"],
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "paths": {
      "@/*": ["./*"],
      "@workspace/ui/*": ["../ui/src/*"],
      "@workspace/types/*": ["../types/src/*"]
    }
  }
}

{
  "name": "@workspace/features",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "lint": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "@workspace/types": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.1.9",
    "@workspace/typescript-config": "workspace:*"
  },
  "exports": {
    "./Timer/*": "./dist/Timer/*.js",
    "./Project/*": "./dist/Project/*.js",
    "./Task/*": "./dist/Task/*.js",
    "./Music/*": "./dist/Music/*.js",
    "./*": "./dist/*.js"
  }
}

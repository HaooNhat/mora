{
  "name": "@workspace/domain",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "lint": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@workspace/typescript-config": "workspace:*"
  },
  "exports": {
    ".": "./dist/index.js",
    "./entities/*": "./dist/entities/*.js",
    "./domain-services/*": "./dist/domain-services/*.js",
    "./domain-events/*": "./dist/domain-events/*.js",
    "./value-objects/*": "./dist/value-objects/*.js",
    "./aggregate/*": "./dist/aggregate/*.js",
    "./focus": "./dist/focus/index.js",
    "./focus/*": "./dist/focus/*.js",
    "./analytic": "./dist/analytic/index.js",
    "./analytic/*": "./dist/analytic/*.js",
    "./mood": "./dist/mood/index.js",
    "./mood/*": "./dist/mood/*.js",
    "./project": "./dist/project/index.js",
    "./project/*": "./dist/project/*.js",
    "./timer": "./dist/timer/index.js",
    "./timer/*": "./dist/timer/*.js",
    "./util": "./dist/utils/index.js",
    "./util/*": "./dist/utils/*.js"
  }
}

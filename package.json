{
  "name": "mora-monorepo",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "start": "turbo run start --filter=@mora/web --filter=@mora/api",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@mora/eslint-config": "workspace:*",
    "@mora/typescript-config": "workspace:*",
    "eslint": "^10.3.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "turbo": "^2.9.12",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2"
  },
  "packageManager": "pnpm@11.1.3+sha512.c85357fe17ca12dd23dd7071822666dfd7e3cb76fe214e3370b5ea2fb34f2a231185509b63e717f3cd0acb38dd3f8d82bcd5e8172400ae678b70ea4fbed0896d",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.1.13",
      "@types/react-dom": "19.1.9"
    },
    "ignoredBuiltDependencies": [
      "@scarf/scarf",
      "core-js-pure"
    ],
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@parcel/watcher",
      "@prisma/engines",
      "@swc/core",
      "@tailwindcss/oxide",
      "bcrypt",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}

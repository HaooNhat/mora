PORT=3001
NODE_ENV=development

# Redis (run via docker-compose)
# Dev: use REDIS_URL=redis://localhost:6379
# Prod (Redis Cloud): set REDIS_URL=host:port + REDIS_PASSWORD + optionally REDIS_TLS=true
REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=your-redis-password
# REDIS_USERNAME=default
# REDIS_TLS=false

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=your-jwt-secret
JWT_REFRESH_SECRET=your-jwt-refresh-secret
JWT_ISSUER=mora-api
JWT_AUDIENCE=mora-web
JWT_ALGORITHM=HS256

SALT_OR_ROUNDS=10

# Resend (https://resend.com) — for email verification
RESEND_API_KEY=re_your_api_key
# RESEND_FROM_EMAIL defaults to onboarding@resend.dev (Resend's shared domain, no custom domain needed)
# RESEND_FROM_EMAIL=onboarding@resend.dev
# Dev only: all emails are redirected to this address (must be your Resend account email)
RESEND_DEV_TO_EMAIL=your-resend-account@email.com
APP_NAME=Mora

# Express session — generate with: openssl rand -base64 64
SESSION_SECRET=your-session-secret

FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001

# PostgreSQL (run via docker-compose)
DATABASE_URL=postgresql://mora:mora@localhost:5432/mora

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback
